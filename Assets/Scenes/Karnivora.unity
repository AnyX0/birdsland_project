  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 52490eb20a5ca1344adc2047db266cc9, type: 3}
    m_FontSize: 28
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 62
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: Walet (Aerodramus fuciphagus) adalah burung berukuran kecil yang terkenal
    karena menghasilkan sarang dari air liurnya yang memiliki nilai ekonomi tinggi.
    Sebagai burung insektivora, walet hidup di gua-gua alami maupun bangunan khusus
    dan menghabiskan sebagian besar waktunya terbang di udara untuk mencari makan
    dengan makanan utama berupa nyamuk, lalat, rayap bersayap, semut terbang, serta
    berbagai serangga kecil lainnya, sehingga berperan dalam membantu mengurangi
    populasi serangga di lingkungan.
